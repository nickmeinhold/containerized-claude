# ── Anthropic ─────────────────────────────────────────────────────
# Auth is handled via OAuth credentials mounted from .claude-credentials.json
# (extracted from macOS Keychain). If using an API key instead, uncomment:
# ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

# ── Agent Identity ───────────────────────────────────────────────
# The agent-loop loads persona-<name>.md (lowercased) automatically.
# e.g. AGENT_NAME=Aria → looks for persona-aria.md
AGENT_NAME=Claudius
MY_EMAIL=claudius@gmail.com

# ── Peer (the other Claude on the other machine) ─────────────────
PEER_EMAIL=friend@gmail.com

# ── Owner (human companion — gets usage reports & failure alerts) ─
OWNER_EMAIL=owner@gmail.com

# ── IMAP (for receiving email) ───────────────────────────────────
# Gmail — create an app password at:
#   https://myaccount.google.com/apppasswords (requires 2FA enabled)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=claudius@gmail.com
IMAP_PASS=REPLACE_WITH_APP_PASSWORD

# ── SMTP (for sending email) ────────────────────────────────────
# Used by the entrypoint to generate /etc/msmtprc at runtime.
# This avoids duplicating the app password in a separate file.
# For docker-compose with a bind-mounted msmtprc, these can be omitted.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# SMTP_USER defaults to MY_EMAIL, SMTP_PASS defaults to IMAP_PASS

# ── Sender Allowlist (defense-in-depth against prompt injection) ──
# Comma-separated email addresses allowed to trigger the agent.
# CRITICAL: Fail-closed — if empty or unset, ALL emails are rejected.
# Both fetch-mail.py and agent-loop.sh enforce this independently.
ALLOWED_SENDERS=owner@gmail.com,friend@gmail.com

# ── GitHub ────────────────────────────────────────────────────────
# Personal Access Token for the gh CLI. Create at:
#   https://github.com/settings/tokens (fine-grained recommended)
# Required scopes: repo, issues, pull requests, read:org
GH_TOKEN=ghp_REPLACE_WITH_PAT

# Git identity for commits
GIT_USER_NAME=Claudius
GIT_USER_EMAIL=gaylejewon@users.noreply.github.com

# Research journal repo (owner/repo format). Cloned to /workspace/repos/<repo>.
# Claudius uses this for persistent memory across invocations.
JOURNAL_REPO=gaylejewon/research-journal

# ── Behavior ─────────────────────────────────────────────────────
# Set to "true" on ONE side to kick off the conversation
SEND_FIRST=false

# Seconds between inbox checks
POLL_INTERVAL=30

# ── Usage Controls ───────────────────────────────────────────────
# Max Claude API round-trips per single invocation.
MAX_TURNS=25

# Weekly turn quota with auto-pacing. Remaining turns are distributed
# evenly across remaining days until reset. Set to 0 to disable.
WEEKLY_TURN_QUOTA=1000

# Weekly reset schedule. ISO weekday: 1=Mon, 2=Tue, ..., 7=Sun.
# Combined with QUOTA_RESET_HOUR_UTC to define the reset boundary.
# Example: day 4 + hour 6 = Thursday 06:00 UTC (1pm Bangkok ICT).
QUOTA_RESET_DAY=4
QUOTA_RESET_HOUR_UTC=6

# Max retries per email before giving up and notifying owner.
MAX_RETRIES_PER_MESSAGE=2

# How often to email a usage report to OWNER_EMAIL (in invocations).
# Includes daily pace, weekly quota, and monthly token stats. Set to 0 to disable.
REPORT_EVERY_N=10

# Restrict processing to UTC hours (optional). Format: "HH-HH".
# Supports wrap-around (e.g., "22-06" = 10pm to 6am UTC).
# ACTIVE_HOURS_UTC=06-22
