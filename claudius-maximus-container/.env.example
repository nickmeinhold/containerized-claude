# ── Anthropic ─────────────────────────────────────────────────────
# Auth is handled via OAuth credentials mounted from .claude-credentials.json
# (extracted from macOS Keychain). If using an API key instead, uncomment:
# ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

# ── Agent Identity ───────────────────────────────────────────────
# The agent-loop loads persona-<name>.md (lowercased) automatically.
# e.g. AGENT_NAME=Aria → looks for persona-aria.md
AGENT_NAME=Claudius
MY_EMAIL=claudius@gmail.com

# ── Peer (the other Claude on the other machine) ─────────────────
PEER_EMAIL=friend@gmail.com

# ── IMAP (for receiving email) ───────────────────────────────────
# Gmail — create an app password at:
#   https://myaccount.google.com/apppasswords (requires 2FA enabled)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=claudius@gmail.com
IMAP_PASS=REPLACE_WITH_APP_PASSWORD

# ── Sender Allowlist (defense-in-depth against prompt injection) ──
# Comma-separated email addresses allowed to trigger the agent.
# CRITICAL: Fail-closed — if empty or unset, ALL emails are rejected.
# Both fetch-mail.py and agent-loop.sh enforce this independently.
ALLOWED_SENDERS=owner@gmail.com,friend@gmail.com

# ── Behavior ─────────────────────────────────────────────────────
# Set to "true" on ONE side to kick off the conversation
SEND_FIRST=false

# Seconds between inbox checks
POLL_INTERVAL=30

# ── Cost Controls ────────────────────────────────────────────────
# Max Claude API round-trips per single invocation.
MAX_TURNS=25

# Daily spend cap in USD. Uses actual cost reported by Claude CLI.
# Default $5/day. Set to 0 to disable budget enforcement.
DAILY_BUDGET_USD=5.00

# Hour (0-23 UTC) when the daily budget resets.
BUDGET_RESET_HOUR_UTC=0

# Max retries per email before giving up and notifying owner.
MAX_RETRIES_PER_MESSAGE=2

# Restrict processing to UTC hours (optional). Format: "HH-HH".
# Supports wrap-around (e.g., "22-06" = 10pm to 6am UTC).
# ACTIVE_HOURS_UTC=06-22
